VITE_USE_MOCK_DATA=true
VITE_SAP_API_URL=http://localhost:3001/api
VITE_SAP_WS_URL=ws://localhost:3001/ws

PORT=3001
CORS_ORIGIN=http://localhost:5173
DASHBOARD_CACHE_TTL_MS=300000
SAP_B1_USE_MOCK=true

# Future SAP B1 backend settings
SAP_B1_SERVICE_LAYER_URL=https://sap-server:50000/b1s/v1
SAP_B1_COMPANY_DB=SBODEMOCL
SAP_B1_USERNAME=
SAP_B1_PASSWORD=
SAP_B1_TIMEOUT_MS=30000
SAP_B1_SESSION_TTL_MS=1500000
SAP_B1_REJECT_UNAUTHORIZED=true
SAP_B1_PING_PATH=/BusinessPartners?$top=1&$select=CardCode

# Optional SAP B1 dataset paths. Each endpoint must return JSON matching the dashboard shape.
# Good candidates are Service Layer SQLQueries/List endpoints or normalized backend views.
SAP_B1_KPIS_PATH=
SAP_B1_VENTAS_REGION_PATH=
SAP_B1_PRODUCTOS_TOP_PATH=
SAP_B1_TENDENCIAS_MENSUAL_PATH=
SAP_B1_INVENTARIO_CATEGORIA_PATH=
SAP_B1_CLIENTES_INDUSTRIA_PATH=
SAP_B1_ORDENES_RECIENTES_PATH=
SAP_B1_DESEMPENO_PATH=
